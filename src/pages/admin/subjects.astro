---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getLocale, t } from '../../i18n';

const locale = getLocale(Astro.cookies.get('lang')?.value);
---

<DashboardLayout title={t(locale, 'nav.subjects')}>
  <div>
    <div class="flex justify-between items-center mb-4">
      <p id="subject-count" class="text-sm text-gray-500">{t(locale, 'common.loading')}</p>
      <button id="add-subject-btn" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">
        {t(locale, 'subjects.addSubject')}
      </button>
    </div>

    <div id="subject-table" class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-1/5">{t(locale, 'common.name')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'common.description')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-[120px]">{t(locale, 'common.created')}</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase w-[180px]">{t(locale, 'common.actions')}</th>
          </tr>
        </thead>
        <tbody id="subject-rows" class="divide-y divide-gray-200"></tbody>
      </table>
    </div>
  </div>

  <!-- Add/Edit Subject Modal -->
  <div id="subject-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 id="modal-title" class="text-lg font-semibold mb-4">{t(locale, 'subjects.addSubject')}</h3>

      <form id="subject-form" class="space-y-4">
        <div id="subject-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

        <div>
          <label for="subject-name" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.name')}</label>
          <input id="subject-name" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>

        <div>
          <label for="subject-description" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'subjects.descriptionOptional')}</label>
          <textarea id="subject-description" class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="3"></textarea>
        </div>

        <div class="flex gap-2">
          <button type="button" id="cancel-subject" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
          <button type="submit" id="submit-subject" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.save')}</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-[100]">
    <div class="bg-white rounded-lg p-6 w-full max-w-sm shadow-xl">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">{t(locale, 'subjects.deleteSubject')}</h3>
      <p id="delete-message" class="text-sm text-gray-600 mb-4"></p>
      <div id="delete-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm mb-4"></div>
      <div class="flex gap-2">
        <button id="cancel-delete" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
        <button id="confirm-delete" class="flex-1 bg-red-600 text-white py-2 px-4 rounded-md text-sm hover:bg-red-700 disabled:opacity-50">{t(locale, 'common.delete')}</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const tbody = document.getElementById('subject-rows')!;
  const countEl = document.getElementById('subject-count')!;

  const subjectModal = document.getElementById('subject-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const subjectForm = document.getElementById('subject-form') as HTMLFormElement;
  const subjectError = document.getElementById('subject-error')!;
  const submitBtn = document.getElementById('submit-subject') as HTMLButtonElement;
  const nameInput = document.getElementById('subject-name') as HTMLInputElement;
  const descInput = document.getElementById('subject-description') as HTMLTextAreaElement;

  const deleteModal = document.getElementById('delete-modal')!;
  const deleteMessage = document.getElementById('delete-message')!;
  const deleteError = document.getElementById('delete-error')!;
  const confirmDeleteBtn = document.getElementById('confirm-delete') as HTMLButtonElement;

  let subjects: any[] = [];
  let editingId: string | null = null;
  let deletingId: string | null = null;

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderSubjects() {
    const count = subjects.length;
    countEl.textContent = count === 1
      ? __t('subjects.subjectCountOne', { count: '1' })
      : __t('subjects.subjectCount', { count: String(count) });

    if (subjects.length === 0) {
      tbody.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">${escapeHtml(__t('subjects.noSubjects'))}</td></tr>`;
      return;
    }

    tbody.innerHTML = subjects.map(s => {
      const created = new Date(s.created_at).toLocaleDateString();
      return `<tr class="hover:bg-gray-50">
        <td class="px-4 py-3 text-sm text-gray-900 font-medium">${escapeHtml(s.name)}</td>
        <td class="px-4 py-3 text-sm text-gray-500">${s.description ? escapeHtml(s.description) : '<span class="text-gray-300">&mdash;</span>'}</td>
        <td class="px-4 py-3 text-sm text-gray-500">${created}</td>
        <td class="px-4 py-3 text-sm">
          <div class="flex justify-end gap-2">
            <button data-edit="${s.id}" class="px-3 py-1.5 border border-blue-300 text-blue-700 bg-blue-50 rounded-md text-xs font-medium hover:bg-blue-100">${escapeHtml(__t('common.edit'))}</button>
            <button data-delete="${s.id}" class="px-3 py-1.5 border border-red-300 text-red-700 bg-red-50 rounded-md text-xs font-medium hover:bg-red-100">${escapeHtml(__t('common.delete'))}</button>
          </div>
        </td>
      </tr>`;
    }).join('');
  }

  function loadSubjects() {
    fetch('/api/admin/subjects', { credentials: 'include' })
      .then(res => res.ok ? res.json() : { data: [] })
      .then(body => {
        subjects = body.data;
        renderSubjects();
      });
  }

  loadSubjects();

  // Add Subject
  document.getElementById('add-subject-btn')!.addEventListener('click', () => {
    editingId = null;
    modalTitle.textContent = __t('subjects.addSubject');
    submitBtn.textContent = __t('common.save');
    nameInput.value = '';
    descInput.value = '';
    subjectError.classList.add('hidden');
    subjectModal.classList.remove('hidden');
    nameInput.focus();
  });

  // Edit Subject - delegation
  tbody.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-edit]') as HTMLElement | null;
    if (!btn) return;
    const subject = subjects.find(s => s.id === btn.dataset.edit);
    if (!subject) return;

    editingId = subject.id;
    modalTitle.textContent = __t('subjects.editSubject');
    submitBtn.textContent = __t('common.save');
    nameInput.value = subject.name;
    descInput.value = subject.description || '';
    subjectError.classList.add('hidden');
    subjectModal.classList.remove('hidden');
    nameInput.focus();
  });

  // Delete Subject - delegation
  tbody.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-delete]') as HTMLElement | null;
    if (!btn) return;
    const subject = subjects.find(s => s.id === btn.dataset.delete);
    if (!subject) return;

    deletingId = subject.id;
    deleteMessage.textContent = __t('subjects.confirmDelete', { name: subject.name });
    deleteError.classList.add('hidden');
    deleteModal.classList.remove('hidden');
  });

  // Cancel modals
  document.getElementById('cancel-subject')!.addEventListener('click', () => {
    subjectModal.classList.add('hidden');
    subjectForm.reset();
  });
  document.getElementById('cancel-delete')!.addEventListener('click', () => {
    deleteModal.classList.add('hidden');
    deletingId = null;
  });

  // Submit add/edit
  subjectForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    subjectError.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = __t('common.saving');

    const name = nameInput.value.trim();
    const description = descInput.value.trim();

    try {
      const isEdit = editingId !== null;
      const url = isEdit ? `/api/admin/subjects/${editingId}` : '/api/admin/subjects';
      const method = isEdit ? 'PATCH' : 'POST';

      const res = await fetch(url, {
        method,
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description: description || undefined }),
      });

      const body = await res.json();
      if (!res.ok) {
        subjectError.textContent = body.error || __t('subjects.failedSave');
        subjectError.classList.remove('hidden');
        return;
      }

      subjectModal.classList.add('hidden');
      subjectForm.reset();
      loadSubjects();
    } catch {
      subjectError.textContent = __t('common.networkError');
      subjectError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = __t('common.save');
    }
  });

  // Confirm delete
  confirmDeleteBtn.addEventListener('click', async () => {
    if (!deletingId) return;
    deleteError.classList.add('hidden');
    confirmDeleteBtn.disabled = true;
    confirmDeleteBtn.textContent = __t('common.deleting');

    try {
      const res = await fetch(`/api/admin/subjects/${deletingId}`, {
        method: 'DELETE',
        credentials: 'include',
      });

      if (!res.ok) {
        const body = await res.json();
        deleteError.textContent = body.error || __t('subjects.failedDelete');
        deleteError.classList.remove('hidden');
        return;
      }

      subjects = subjects.filter(s => s.id !== deletingId);
      deleteModal.classList.add('hidden');
      deletingId = null;
      renderSubjects();
    } catch {
      deleteError.textContent = __t('common.networkError');
      deleteError.classList.remove('hidden');
    } finally {
      confirmDeleteBtn.disabled = false;
      confirmDeleteBtn.textContent = __t('common.delete');
    }
  });
</script>
