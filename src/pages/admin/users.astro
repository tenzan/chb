---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getLocale, t } from '../../i18n';

const locale = getLocale(Astro.cookies.get('lang')?.value);
---

<DashboardLayout title={t(locale, 'nav.users')}>
  <div>
    <div class="flex justify-between items-center mb-4">
      <p id="user-count" class="text-sm text-gray-500">{t(locale, 'common.loading')}</p>
      <div class="flex gap-2">
        <button id="create-user-btn" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">
          {t(locale, 'users.createUser')}
        </button>
        <button id="invite-user-btn" class="border border-blue-600 text-blue-600 px-4 py-2 rounded-md text-sm hover:bg-blue-50">
          {t(locale, 'users.inviteUser')}
        </button>
      </div>
    </div>

    <!-- Role Filter Chips -->
    <div id="role-chips" class="flex gap-2 flex-wrap mb-4">
      <button data-role="All" class="role-chip px-3 py-1 text-sm rounded-full border bg-blue-600 text-white border-blue-600">{t(locale, 'common.all')}</button>
    </div>

    <!-- Search -->
    <div class="relative mb-4">
      <input
        id="search-input"
        type="text"
        placeholder={t(locale, 'common.search')}
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm pr-8 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
      />
      <button
        id="clear-search"
        class="hidden absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
      >
        &#10005;
      </button>
    </div>

    <div id="user-table" class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'common.name')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'common.email')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'common.roles')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'common.created')}</th>
          </tr>
        </thead>
        <tbody id="user-rows" class="divide-y divide-gray-200"></tbody>
      </table>
    </div>
  </div>

  <!-- Create User Modal -->
  <div id="create-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold mb-4">{t(locale, 'users.createUser')}</h3>

      <form id="create-form" class="space-y-4">
        <div id="create-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">{t(locale, 'common.role')}</label>
          <div class="space-y-2" id="create-roles">
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Admin" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Admin')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Personnel" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Personnel')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Tutor" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Tutor')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Accountant" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Accountant')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Parent" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Parent')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="create-role" value="Student" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Student')}</span></label>
          </div>
        </div>

        <!-- Common fields -->
        <div>
          <label for="create-name" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.name')} <span class="text-red-500">*</span></label>
          <input id="create-name" type="text" required class="required-field w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
        </div>

        <!-- Staff fields (shown for non-Student roles) -->
        <div id="create-staff-fields">
          <div class="space-y-4">
            <div>
              <label for="create-email" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.email')} <span class="text-red-500">*</span></label>
              <input id="create-email" type="email" class="required-field w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
            </div>
            <div>
              <label for="create-password" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.password')} <span class="text-red-500">*</span></label>
              <input id="create-password" type="password" minlength="6" class="required-field w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
            </div>
          </div>
        </div>

        <!-- Parent fields -->
        <div id="create-parent-fields" class="hidden space-y-4">
          <div>
            <label for="create-phone" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'users.phoneOptional')}</label>
            <input id="create-phone" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
          </div>
        </div>

        <!-- Student fields -->
        <div id="create-student-fields" class="hidden space-y-4">
          <div class="relative">
            <label class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'users.parentLabel')} <span class="text-red-500">*</span></label>
            <div id="parent-search-wrapper" class="flex items-center border border-gray-300 rounded-md bg-white transition-colors">
              <input
                id="parent-search-input"
                type="text"
                autocomplete="off"
                placeholder={t(locale, 'users.searchParents')}
                class="flex-1 px-3 py-2 text-sm rounded-md outline-none bg-transparent"
              />
              <button id="clear-parent" class="hidden px-2 py-2 text-gray-400 hover:text-gray-600" type="button">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <input type="hidden" id="create-parent-id" />
            <div id="parent-dropdown" class="hidden absolute z-40 mt-1 w-full bg-white border border-gray-200 rounded-md shadow-lg max-h-48 overflow-y-auto"></div>
          </div>
          <div>
            <label for="create-birthday" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'users.birthdayOptional')}</label>
            <input id="create-birthday" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
          </div>
          <div>
            <label for="create-description" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'users.descriptionOptional')}</label>
            <textarea id="create-description" class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="2"></textarea>
          </div>
        </div>

        <!-- Note (common optional) -->
        <div>
          <label for="create-note" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'users.noteOptional')}</label>
          <textarea id="create-note" class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="2"></textarea>
        </div>

        <div class="flex gap-2">
          <button type="button" id="cancel-create" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.create')}</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Invite User Modal -->
  <div id="invite-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 class="text-lg font-semibold mb-4">{t(locale, 'users.inviteUser')}</h3>

      <!-- Invite Form -->
      <form id="invite-form" class="space-y-4">
        <div id="invite-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

        <div>
          <label for="invite-email" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.email')}</label>
          <input id="invite-email" type="email" required class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">{t(locale, 'common.role')}</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="invite-role" value="Admin" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Admin')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="invite-role" value="Personnel" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Personnel')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="invite-role" value="Tutor" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Tutor')}</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="invite-role" value="Accountant" class="text-blue-600" /><span class="text-sm text-gray-700">{t(locale, 'roles.Accountant')}</span></label>
          </div>
        </div>

        <div class="flex gap-2">
          <button type="button" id="cancel-invite" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'users.createInvite')}</button>
        </div>
      </form>

      <!-- Invite Success -->
      <div id="invite-success" class="hidden">
        <p class="text-sm text-gray-600 mb-2">{t(locale, 'users.inviteCreated')}</p>
        <div id="invite-link-display" class="bg-gray-50 p-3 rounded-md text-sm break-all"></div>
        <div class="flex gap-2 mt-4">
          <button id="copy-invite-link" class="flex-1 border border-blue-600 text-blue-600 py-2 px-4 rounded-md hover:bg-blue-50">
            {t(locale, 'users.copyLink')}
          </button>
          <button id="done-invite" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700">
            {t(locale, 'users.done')}
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Roles Modal -->
  <div id="roles-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-sm">
      <h3 id="roles-title" class="text-lg font-semibold mb-4"></h3>

      <div id="roles-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm mb-4"></div>

      <div class="space-y-2 mb-4" id="roles-checkboxes">
        <label class="flex items-center gap-2"><input type="checkbox" value="Admin" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Admin')}</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" value="Personnel" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Personnel')}</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" value="Tutor" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Tutor')}</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" value="Accountant" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Accountant')}</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" value="Parent" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Parent')}</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" value="Student" class="rounded border-gray-300" /><span class="text-sm">{t(locale, 'roles.Student')}</span></label>
      </div>

      <div class="flex gap-2">
        <button id="cancel-roles" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
        <button id="save-roles" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.save')}</button>
      </div>
    </div>
  </div>

  <!-- Reset Password Modal -->
  <div id="reset-password-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 class="text-lg font-semibold mb-4">Password Reset Link</h3>
      <p class="text-sm text-gray-600 mb-2">Share this link with the user. It expires in 1 hour.</p>
      <div id="reset-link-display" class="bg-gray-50 p-3 rounded-md text-sm break-all"></div>
      <div class="flex gap-2 mt-4">
        <button id="copy-reset-link" class="flex-1 border border-blue-600 text-blue-600 py-2 px-4 rounded-md hover:bg-blue-50">
          Copy Link
        </button>
        <button id="done-reset" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700">
          Done
        </button>
      </div>
    </div>
  </div>

  <!-- Edit Student Modal -->
  <div id="edit-student-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 class="text-lg font-semibold mb-4">{t(locale, 'users.editStudent')}</h3>

      <form id="edit-student-form" class="space-y-4">
        <div id="edit-student-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

        <div>
          <label for="edit-student-name" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.name')}</label>
          <input id="edit-student-name" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>

        <div>
          <label for="edit-student-birthday" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.birthday')}</label>
          <input id="edit-student-birthday" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>

        <div>
          <label for="edit-student-desc" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.description')}</label>
          <textarea id="edit-student-desc" class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="2"></textarea>
        </div>

        <div>
          <label for="edit-student-note" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'common.note')}</label>
          <textarea id="edit-student-note" class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="2"></textarea>
        </div>

        <div class="flex gap-2">
          <button type="button" id="cancel-edit-student" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.save')}</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  const userTbody = document.getElementById('user-rows')!;
  const userCountEl = document.getElementById('user-count')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const clearSearchBtn = document.getElementById('clear-search')!;
  const roleChipsContainer = document.getElementById('role-chips')!;

  const createModal = document.getElementById('create-modal')!;
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const createError = document.getElementById('create-error')!;
  const createSubmitBtn = createForm.querySelector('button[type="submit"]') as HTMLButtonElement;

  const inviteModal = document.getElementById('invite-modal')!;
  const inviteForm = document.getElementById('invite-form') as HTMLFormElement;
  const inviteError = document.getElementById('invite-error')!;
  const inviteSubmitBtn = inviteForm.querySelector('button[type="submit"]') as HTMLButtonElement;
  const inviteSuccess = document.getElementById('invite-success')!;
  const inviteLinkDisplay = document.getElementById('invite-link-display')!;

  const rolesModal = document.getElementById('roles-modal')!;
  const rolesTitle = document.getElementById('roles-title')!;
  const rolesError = document.getElementById('roles-error')!;
  const rolesCheckboxes = document.getElementById('roles-checkboxes')!;
  const saveRolesBtn = document.getElementById('save-roles') as HTMLButtonElement;

  const editStudentModal = document.getElementById('edit-student-modal')!;
  const editStudentForm = document.getElementById('edit-student-form') as HTMLFormElement;
  const editStudentError = document.getElementById('edit-student-error')!;
  const editStudentSubmitBtn = editStudentForm.querySelector('button[type="submit"]') as HTMLButtonElement;

  let users: any[] = [];
  let activeRole = 'All';
  let editingUserId: string | null = null;
  let editingUserOriginalRoles: string[] = [];
  const resetPasswordModal = document.getElementById('reset-password-modal')!;
  const resetLinkDisplay = document.getElementById('reset-link-display')!;

  let editingStudentId: string | null = null;
  let currentInviteLink = '';
  let expandedUserId: string | null = null;

  const ROLE_COLORS: Record<string, string> = {
    Admin: 'bg-red-100 text-red-800',
    Personnel: 'bg-purple-100 text-purple-800',
    Tutor: 'bg-green-100 text-green-800',
    Accountant: 'bg-teal-100 text-teal-800',
    Parent: 'bg-blue-100 text-blue-800',
    Student: 'bg-orange-100 text-orange-800',
  };

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function translateRole(role: string) {
    return __t(`roles.${role}`) || role;
  }

  function getFiltered() {
    let filtered = users;

    // Status filter (Pending chip)
    if (activeRole === 'Pending') {
      filtered = filtered.filter(u => u.status === 'pending');
    } else if (activeRole !== 'All') {
      // Role filter
      filtered = filtered.filter(u => u.roles.includes(activeRole));
    }

    // Search filter
    const q = searchInput.value.toLowerCase();
    if (q) {
      filtered = filtered.filter(u =>
        u.name.toLowerCase().includes(q) ||
        u.email.toLowerCase().includes(q)
      );
    }

    return filtered;
  }

  const ALL_ROLES = ['Admin', 'Personnel', 'Tutor', 'Accountant', 'Parent', 'Student'];

  function updateChips() {
    const rolesInUse = new Set<string>();
    users.forEach(u => u.roles.forEach((r: string) => rolesInUse.add(r)));
    const pendingCount = users.filter(u => u.status === 'pending').length;

    // If active filter no longer has matching users, reset to All
    if (activeRole === 'Pending' && pendingCount === 0) {
      activeRole = 'All';
    } else if (activeRole !== 'All' && activeRole !== 'Pending' && !rolesInUse.has(activeRole)) {
      activeRole = 'All';
    }

    const chips: string[] = [];
    ALL_ROLES.forEach(role => {
      if (rolesInUse.has(role)) {
        chips.push(`<button data-role="${role}" class="role-chip px-3 py-1 text-sm rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50">${escapeHtml(translateRole(role))}</button>`);
      }
    });
    if (pendingCount > 0) {
      chips.push(`<button data-role="Pending" class="role-chip px-3 py-1 text-sm rounded-full border border-amber-400 bg-amber-50 text-amber-800 hover:bg-amber-100">${escapeHtml(__t('users.pendingCount', { count: String(pendingCount) }))}</button>`);
    }

    roleChipsContainer.innerHTML = `<button data-role="All" class="role-chip px-3 py-1 text-sm rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50">${escapeHtml(__t('common.all'))}</button>` + chips.join('');
    updateChipStyles();
  }

  function renderUsers() {
    const filtered = getFiltered();
    const q = searchInput.value;
    const isFiltered = activeRole !== 'All' || q;
    userCountEl.textContent = isFiltered
      ? __t('users.userCountFiltered', { filtered: String(filtered.length), total: String(users.length) })
      : __t('users.userCount', { count: String(users.length) });
    clearSearchBtn.classList.toggle('hidden', !q);

    userTbody.innerHTML = filtered.map(u => {
      const isExpanded = expandedUserId === u.id;
      const roleBadges = u.roles.map((r: string) => {
        const color = ROLE_COLORS[r] || 'bg-gray-100 text-gray-800';
        return `<span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full ${color}">${escapeHtml(translateRole(r))}</span>`;
      }).join('');

      // Status badge for non-active users
      let statusBadge = '';
      if (u.status === 'pending') {
        statusBadge = `<span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800">${escapeHtml(__t('users.pending'))}</span>`;
      } else if (u.status === 'suspended') {
        statusBadge = `<span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-red-100 text-red-800">${escapeHtml(__t('users.suspended'))}</span>`;
      }

      const createdDate = new Date(u.created_at).toLocaleDateString();

      let expandedRow = '';
      if (isExpanded) {
        const details: string[] = [];

        if (u.phone) details.push(`<div><span class="font-medium text-gray-600">${escapeHtml(__t('common.phone'))}:</span> ${escapeHtml(u.phone)}</div>`);
        if (u.birthday) details.push(`<div><span class="font-medium text-gray-600">${escapeHtml(__t('common.birthday'))}:</span> ${escapeHtml(u.birthday)}</div>`);
        if (u.description) details.push(`<div><span class="font-medium text-gray-600">${escapeHtml(__t('common.description'))}:</span> ${escapeHtml(u.description)}</div>`);
        if (u.note) details.push(`<div><span class="font-medium text-gray-600">${escapeHtml(__t('common.note'))}:</span> ${escapeHtml(u.note)}</div>`);

        if (u.parents && u.parents.length > 0) {
          const parentNames = u.parents.map((p: any) => `${escapeHtml(p.name)} (${escapeHtml(p.email)})`).join(', ');
          details.push(`<div><span class="font-medium text-gray-600">${escapeHtml(__t('users.parents'))}:</span> ${parentNames}</div>`);
        }

        if (details.length === 0) {
          details.push(`<div class="text-gray-400 italic">${escapeHtml(__t('common.noAdditionalDetails'))}</div>`);
        }

        // Action buttons
        const actions: string[] = [];
        actions.push(`<button data-edit-roles="${u.id}" class="text-sm text-blue-600 hover:text-blue-800">${escapeHtml(__t('users.editRoles'))}</button>`);
        if (u.roles.includes('Student')) {
          actions.push(`<button data-edit-student="${u.id}" class="text-sm text-blue-600 hover:text-blue-800">${escapeHtml(__t('users.editStudent'))}</button>`);
        }
        if (u.status !== 'pending') {
          actions.push(`<button data-reset-password="${u.id}" class="text-sm text-amber-600 hover:text-amber-800">Reset Password</button>`);
        }
        if (u.status === 'pending' && u.inviteId) {
          actions.push(`<button data-revoke-invite="${u.inviteId}" data-revoke-user="${u.id}" class="text-sm text-red-600 hover:text-red-800">${escapeHtml(__t('users.revokeInvite'))}</button>`);
        }

        expandedRow = `<tr data-expanded-for="${u.id}">
          <td colspan="4" class="px-4 pb-4 pt-0 bg-blue-50 border-b border-gray-200">
            <div class="border-l-3 border-blue-500 pl-4 ml-1 py-1">
              <div class="flex justify-between items-start">
                <div class="space-y-1.5 text-sm text-gray-700">${details.join('')}</div>
                <div class="flex gap-3">${actions.join('')}</div>
              </div>
            </div>
          </td>
        </tr>`;
      }

      return `<tr data-user-row="${u.id}" class="group/row cursor-pointer hover:bg-gray-50${isExpanded ? ' bg-blue-50' : ''}">
        <td class="px-4 py-3 text-sm${isExpanded ? ' font-semibold text-gray-900' : ' text-gray-900'}">${u.name ? escapeHtml(u.name) : '<span class="text-gray-400">\u2014</span>'}${statusBadge ? ' ' + statusBadge : ''}</td>
        <td class="px-4 py-3 text-sm text-gray-500">
          <span class="inline-flex items-center gap-1">
            ${escapeHtml(u.email)}
            <button data-copy-email="${escapeHtml(u.email)}" class="opacity-0 group-hover/row:opacity-100 transition-opacity text-gray-400 hover:text-gray-600" title="${escapeHtml(__t('common.copyEmail'))}">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke-width="2"/></svg>
            </button>
          </span>
        </td>
        <td class="px-4 py-3">
          <div class="flex gap-1 flex-wrap">${roleBadges}</div>
        </td>
        <td class="px-4 py-3 text-sm text-gray-500">${createdDate}</td>
      </tr>${expandedRow}`;
    }).join('');
  }

  function updateChipStyles() {
    document.querySelectorAll('.role-chip').forEach(chip => {
      const role = (chip as HTMLElement).dataset.role;
      if (role === activeRole) {
        chip.className = 'role-chip px-3 py-1 text-sm rounded-full border bg-blue-600 text-white border-blue-600';
      } else if (role === 'Pending') {
        chip.className = 'role-chip px-3 py-1 text-sm rounded-full border border-amber-400 bg-amber-50 text-amber-800 hover:bg-amber-100';
      } else {
        chip.className = 'role-chip px-3 py-1 text-sm rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50';
      }
    });
  }

  function loadUsers() {
    fetch('/api/admin/users', { credentials: 'include' })
      .then(res => res.ok ? res.json() : { data: [] })
      .then(body => {
        users = body.data;
        updateChips();
        renderUsers();
      });
  }

  loadUsers();

  // Role chip click
  document.getElementById('role-chips')!.addEventListener('click', (e) => {
    const chip = (e.target as HTMLElement).closest('.role-chip') as HTMLElement | null;
    if (!chip) return;

    activeRole = chip.dataset.role!;
    expandedUserId = null;
    updateChipStyles();
    renderUsers();
  });

  // Search
  searchInput.addEventListener('input', () => {
    expandedUserId = null;
    renderUsers();
  });
  clearSearchBtn.addEventListener('click', () => {
    searchInput.value = '';
    expandedUserId = null;
    renderUsers();
  });

  // Row click to expand/collapse
  userTbody.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Handle action buttons - don't toggle row
    if (target.closest('[data-edit-roles]') || target.closest('[data-edit-student]') || target.closest('[data-copy-email]') || target.closest('[data-revoke-invite]') || target.closest('[data-reset-password]')) {
      return;
    }

    const row = target.closest('[data-user-row]') as HTMLElement | null;
    if (!row) return;
    const userId = row.dataset.userRow!;
    expandedUserId = expandedUserId === userId ? null : userId;
    renderUsers();
  });

  // Copy email - delegation
  userTbody.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-copy-email]') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const email = btn.dataset.copyEmail!;
    await navigator.clipboard.writeText(email);
    const svg = btn.querySelector('svg')!;
    const original = svg.outerHTML;
    svg.outerHTML = '<svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    setTimeout(() => {
      const tick = btn.querySelector('svg');
      if (tick) tick.outerHTML = original;
    }, 1500);
  });

  // Revoke invite - delegation
  userTbody.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-revoke-invite]') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const inviteId = btn.dataset.revokeInvite!;
    const userId = btn.dataset.revokeUser!;

    btn.textContent = __t('users.revoking');
    try {
      const res = await fetch(`/api/admin/invites/${inviteId}`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (res.ok) {
        users = users.filter(u => u.id !== userId);
        expandedUserId = null;
        updateChips();
        renderUsers();
      } else {
        btn.textContent = __t('users.revokeInvite');
      }
    } catch {
      btn.textContent = __t('users.revokeInvite');
    }
  });

  // Reset Password - delegation
  userTbody.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-reset-password]') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const userId = btn.dataset.resetPassword!;

    btn.textContent = 'Generating...';
    try {
      const res = await fetch('/api/admin/password-reset', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId }),
      });
      const body = await res.json();
      if (!res.ok) {
        btn.textContent = 'Reset Password';
        alert(body.error || 'Failed to generate reset link');
        return;
      }
      const resetUrl = `${window.location.origin}/reset-password?token=${body.data.resetToken}`;
      resetLinkDisplay.textContent = resetUrl;
      resetPasswordModal.classList.remove('hidden');
    } catch {
      alert('Network error');
    } finally {
      btn.textContent = 'Reset Password';
    }
  });

  // Copy reset link
  document.getElementById('copy-reset-link')!.addEventListener('click', async () => {
    await navigator.clipboard.writeText(resetLinkDisplay.textContent!);
    const btn = document.getElementById('copy-reset-link')!;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy Link'; }, 1500);
  });

  // Done reset modal
  document.getElementById('done-reset')!.addEventListener('click', () => {
    resetPasswordModal.classList.add('hidden');
  });

  // Edit Roles - delegation on tbody (handles buttons in expanded rows)
  userTbody.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-edit-roles]') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const user = users.find(u => u.id === btn.dataset.editRoles);
    if (!user) return;
    editingUserId = user.id;
    editingUserOriginalRoles = [...user.roles];
    rolesTitle.textContent = __t('users.editRolesFor', { name: user.name });
    rolesError.classList.add('hidden');
    rolesCheckboxes.querySelectorAll('input[type="checkbox"]').forEach((cb: Element) => {
      (cb as HTMLInputElement).checked = user.roles.includes((cb as HTMLInputElement).value);
    });
    rolesModal.classList.remove('hidden');
  });

  // Edit Student - delegation
  userTbody.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-edit-student]') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const student = users.find(u => u.id === btn.dataset.editStudent);
    if (!student) return;
    editingStudentId = student.id;
    (document.getElementById('edit-student-name') as HTMLInputElement).value = student.name;
    (document.getElementById('edit-student-birthday') as HTMLInputElement).value = student.birthday || '';
    (document.getElementById('edit-student-desc') as HTMLTextAreaElement).value = student.description || '';
    (document.getElementById('edit-student-note') as HTMLTextAreaElement).value = student.note || '';
    editStudentError.classList.add('hidden');
    editStudentModal.classList.remove('hidden');
  });

  // Cancel/Save roles
  document.getElementById('cancel-roles')!.addEventListener('click', () => {
    rolesModal.classList.add('hidden');
    editingUserId = null;
  });

  saveRolesBtn.addEventListener('click', async () => {
    if (!editingUserId) return;
    rolesError.classList.add('hidden');
    saveRolesBtn.disabled = true;
    saveRolesBtn.textContent = __t('common.saving');

    const selected = Array.from(rolesCheckboxes.querySelectorAll('input[type="checkbox"]:checked'))
      .map(cb => (cb as HTMLInputElement).value);
    const add = selected.filter(r => !editingUserOriginalRoles.includes(r));
    const remove = editingUserOriginalRoles.filter(r => !selected.includes(r));

    if (add.length === 0 && remove.length === 0) {
      rolesModal.classList.add('hidden');
      editingUserId = null;
      saveRolesBtn.disabled = false;
      saveRolesBtn.textContent = __t('common.save');
      return;
    }

    try {
      const res = await fetch(`/api/admin/users/${editingUserId}/roles`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ add, remove }),
      });

      const body = await res.json();
      if (!res.ok) {
        rolesError.textContent = body.error || __t('users.failedUpdateRoles');
        rolesError.classList.remove('hidden');
        return;
      }

      users = users.map(u => u.id === editingUserId ? { ...u, roles: body.data.roles } : u);
      renderUsers();
      rolesModal.classList.add('hidden');
      editingUserId = null;
    } catch {
      rolesError.textContent = __t('common.networkError');
      rolesError.classList.remove('hidden');
    } finally {
      saveRolesBtn.disabled = false;
      saveRolesBtn.textContent = __t('common.save');
    }
  });

  // Edit Student form
  document.getElementById('cancel-edit-student')!.addEventListener('click', () => {
    editStudentModal.classList.add('hidden');
    editStudentForm.reset();
    editStudentError.classList.add('hidden');
    editingStudentId = null;
  });

  editStudentForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!editingStudentId) return;
    editStudentError.classList.add('hidden');
    editStudentSubmitBtn.disabled = true;
    editStudentSubmitBtn.textContent = __t('common.saving');

    const name = (document.getElementById('edit-student-name') as HTMLInputElement).value;
    const birthday = (document.getElementById('edit-student-birthday') as HTMLInputElement).value;
    const description = (document.getElementById('edit-student-desc') as HTMLTextAreaElement).value;
    const note = (document.getElementById('edit-student-note') as HTMLTextAreaElement).value;

    try {
      const res = await fetch(`/api/admin/students/${editingStudentId}`, {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          birthday: birthday || undefined,
          description: description || undefined,
          note: note || undefined,
        }),
      });

      const body = await res.json();
      if (!res.ok) {
        editStudentError.textContent = body.error || __t('users.failedUpdateStudent');
        editStudentError.classList.remove('hidden');
        return;
      }

      const existing = users.find(u => u.id === editingStudentId)!;
      users = users.map(u => u.id === editingStudentId ? { ...u, ...body.data, parents: existing.parents, roles: existing.roles } : u);
      renderUsers();
      editStudentModal.classList.add('hidden');
      editStudentForm.reset();
      editingStudentId = null;
    } catch {
      editStudentError.textContent = __t('common.networkError');
      editStudentError.classList.remove('hidden');
    } finally {
      editStudentSubmitBtn.disabled = false;
      editStudentSubmitBtn.textContent = __t('common.save');
    }
  });

  // Create User - role-aware form
  const createStaffFields = document.getElementById('create-staff-fields')!;
  const createParentFields = document.getElementById('create-parent-fields')!;
  const createStudentFields = document.getElementById('create-student-fields')!;
  const createEmailInput = document.getElementById('create-email') as HTMLInputElement;
  const createPasswordInput = document.getElementById('create-password') as HTMLInputElement;

  // Toggle fields based on selected role
  createForm.querySelectorAll('input[name="create-role"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const role = (radio as HTMLInputElement).value;
      const isStudent = role === 'Student';
      const isParent = role === 'Parent';

      createStaffFields.classList.toggle('hidden', isStudent);
      createParentFields.classList.toggle('hidden', !isParent);
      createStudentFields.classList.toggle('hidden', !isStudent);

      // Email/password required for non-students
      createEmailInput.required = !isStudent;
      createPasswordInput.required = !isStudent;

      // Reset parent search when switching to student role
      if (isStudent) {
        (document.getElementById('parent-search-input') as HTMLInputElement).value = '';
        (document.getElementById('create-parent-id') as HTMLInputElement).value = '';
        document.getElementById('clear-parent')!.classList.add('hidden');
        document.getElementById('parent-dropdown')!.classList.add('hidden');
      }
    });
  });

  document.getElementById('create-user-btn')!.addEventListener('click', () => {
    createModal.classList.remove('hidden');
  });
  document.getElementById('cancel-create')!.addEventListener('click', () => {
    createModal.classList.add('hidden');
    createForm.reset();
    createError.classList.add('hidden');
    // Reset field visibility
    createStaffFields.classList.remove('hidden');
    createParentFields.classList.add('hidden');
    createStudentFields.classList.add('hidden');
    createEmailInput.required = true;
    createPasswordInput.required = true;
    // Reset parent search
    (document.getElementById('parent-search-input') as HTMLInputElement).value = '';
    (document.getElementById('create-parent-id') as HTMLInputElement).value = '';
    document.getElementById('clear-parent')!.classList.add('hidden');
    document.getElementById('parent-dropdown')!.classList.add('hidden');
  });

  // Parent searchable combobox — all dynamic content is escaped via escapeHtml()
  // to prevent XSS, same pattern used across all admin pages in this codebase.
  const parentSearchInput = document.getElementById('parent-search-input') as HTMLInputElement;
  const parentDropdown = document.getElementById('parent-dropdown')!;
  const parentIdInput = document.getElementById('create-parent-id') as HTMLInputElement;
  const clearParentBtn = document.getElementById('clear-parent')!;

  function showParentDropdown(filter: string) {
    const query = filter.trim().toLowerCase();
    if (!query) {
      parentDropdown.classList.add('hidden');
      return;
    }

    const parentUsers = users.filter((u: any) => u.roles.includes('Parent') && u.name.toLowerCase().includes(query));

    let html = '<div class="py-1">';
    if (parentUsers.length === 0) {
      html += '<div class="px-3 py-2 text-sm text-gray-400">' + escapeHtml(__t('users.noMatchingParents')) + '</div>';
    } else {
      for (const p of parentUsers) {
        html += '<div class="parent-option px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 text-gray-900" data-id="' + escapeHtml(p.id) + '">'
          + escapeHtml(p.name) + ' <span class="text-gray-400">(' + escapeHtml(p.email) + ')</span>'
          + '</div>';
      }
    }
    html += '</div>';

    parentDropdown.innerHTML = html;
    parentDropdown.classList.remove('hidden');
  }

  parentSearchInput.addEventListener('input', () => {
    parentIdInput.value = '';
    showParentDropdown(parentSearchInput.value);
  });

  parentSearchInput.addEventListener('blur', () => {
    setTimeout(() => parentDropdown.classList.add('hidden'), 150);
  });

  parentDropdown.addEventListener('mousedown', (e) => {
    const option = (e.target as HTMLElement).closest('.parent-option') as HTMLElement | null;
    if (!option) return;
    e.preventDefault();
    const id = option.dataset.id!;
    const name = option.textContent?.split('(')[0]?.trim() || '';
    parentIdInput.value = id;
    parentSearchInput.value = name;
    clearParentBtn.classList.remove('hidden');
    parentDropdown.classList.add('hidden');
  });

  clearParentBtn.addEventListener('click', () => {
    parentIdInput.value = '';
    parentSearchInput.value = '';
    clearParentBtn.classList.add('hidden');
  });

  // Clear red border when user starts filling a field
  createForm.addEventListener('input', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('border-red-500')) {
      target.classList.remove('border-red-500', 'ring-1', 'ring-red-500');
    }
  });
  // Clear parent wrapper red border when parent is selected
  parentSearchInput.addEventListener('input', () => {
    const wrapper = document.getElementById('parent-search-wrapper')!;
    wrapper.classList.remove('border-red-500', 'ring-1', 'ring-red-500');
  });

  function highlightInvalidFields(role: string): boolean {
    let valid = true;
    const nameInput = document.getElementById('create-name') as HTMLInputElement;

    // Name is always required
    if (!nameInput.value.trim()) {
      nameInput.classList.add('border-red-500', 'ring-1', 'ring-red-500');
      nameInput.focus();
      valid = false;
    }

    if (role === 'Student') {
      // Parent is required
      if (!parentIdInput.value) {
        const wrapper = document.getElementById('parent-search-wrapper')!;
        wrapper.classList.add('border-red-500', 'ring-1', 'ring-red-500');
        if (valid) parentSearchInput.focus();
        valid = false;
      }
    } else {
      // Email + password required for non-students
      const emailInput = document.getElementById('create-email') as HTMLInputElement;
      const passwordInput = document.getElementById('create-password') as HTMLInputElement;
      if (!emailInput.value.trim()) {
        emailInput.classList.add('border-red-500', 'ring-1', 'ring-red-500');
        if (valid) emailInput.focus();
        valid = false;
      }
      if (!passwordInput.value) {
        passwordInput.classList.add('border-red-500', 'ring-1', 'ring-red-500');
        if (valid) passwordInput.focus();
        valid = false;
      }
    }

    return valid;
  }

  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    createError.classList.add('hidden');

    const selectedRole = (createForm.querySelector('input[name="create-role"]:checked') as HTMLInputElement | null)?.value;
    if (!selectedRole) {
      createError.textContent = __t('users.selectRole');
      createError.classList.remove('hidden');
      return;
    }

    if (!highlightInvalidFields(selectedRole)) {
      return;
    }

    createSubmitBtn.disabled = true;
    createSubmitBtn.textContent = __t('common.creating');

    const name = (document.getElementById('create-name') as HTMLInputElement).value;
    const note = (document.getElementById('create-note') as HTMLTextAreaElement).value;

    try {
      if (selectedRole === 'Student') {
        // Create student via students API
        const parentUserId = (document.getElementById('create-parent-id') as HTMLInputElement).value;
        const birthday = (document.getElementById('create-birthday') as HTMLInputElement).value;
        const description = (document.getElementById('create-description') as HTMLTextAreaElement).value;

        const res = await fetch('/api/admin/students', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            parentUserId,
            birthday: birthday || undefined,
            description: description || undefined,
            note: note || undefined,
          }),
        });

        const body = await res.json();
        if (!res.ok) {
          createError.textContent = body.error || __t('users.failedCreateStudent');
          createError.classList.remove('hidden');
          return;
        }

        // Reload all users to get full data
        createModal.classList.add('hidden');
        createForm.reset();
        createStaffFields.classList.remove('hidden');
        createParentFields.classList.add('hidden');
        createStudentFields.classList.add('hidden');
        createEmailInput.required = true;
        createPasswordInput.required = true;
        loadUsers();
      } else if (selectedRole === 'Parent') {
        // Create parent via parents API
        const email = createEmailInput.value;
        const password = createPasswordInput.value;
        const phone = (document.getElementById('create-phone') as HTMLInputElement).value;

        const res = await fetch('/api/admin/parents', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, phone: phone || undefined, note: note || undefined }),
        });

        const body = await res.json();
        if (!res.ok) {
          createError.textContent = body.error || __t('users.failedCreateParent');
          createError.classList.remove('hidden');
          return;
        }

        createModal.classList.add('hidden');
        createForm.reset();
        createStaffFields.classList.remove('hidden');
        createParentFields.classList.add('hidden');
        createStudentFields.classList.add('hidden');
        loadUsers();
      } else {
        // Create staff user via users API
        const email = createEmailInput.value;
        const password = createPasswordInput.value;

        const res = await fetch('/api/admin/users', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, password, roles: [selectedRole], note: note || undefined }),
        });

        const body = await res.json();
        if (!res.ok) {
          createError.textContent = body.error || __t('users.failedCreateUser');
          createError.classList.remove('hidden');
          return;
        }

        createModal.classList.add('hidden');
        createForm.reset();
        loadUsers();
      }
    } catch {
      createError.textContent = __t('common.networkError');
      createError.classList.remove('hidden');
    } finally {
      createSubmitBtn.disabled = false;
      createSubmitBtn.textContent = __t('common.create');
    }
  });

  // Invite User
  document.getElementById('invite-user-btn')!.addEventListener('click', () => {
    inviteForm.classList.remove('hidden');
    inviteSuccess.classList.add('hidden');
    inviteModal.classList.remove('hidden');
  });
  document.getElementById('cancel-invite')!.addEventListener('click', () => {
    inviteModal.classList.add('hidden');
    inviteForm.reset();
    inviteError.classList.add('hidden');
  });

  inviteForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    inviteError.classList.add('hidden');

    const roleName = (inviteForm.querySelector('input[name="invite-role"]:checked') as HTMLInputElement | null)?.value;
    if (!roleName) {
      inviteError.textContent = __t('users.selectRole');
      inviteError.classList.remove('hidden');
      return;
    }

    inviteSubmitBtn.disabled = true;
    inviteSubmitBtn.textContent = __t('common.creating');

    const email = (document.getElementById('invite-email') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/admin/invites', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, roleName }),
      });

      const body = await res.json();
      if (!res.ok) {
        inviteError.textContent = body.error || __t('users.failedCreateUser');
        inviteError.classList.remove('hidden');
        return;
      }

      currentInviteLink = `${window.location.origin}/accept-invite?token=${body.data.inviteToken}`;
      inviteLinkDisplay.textContent = currentInviteLink;
      inviteForm.classList.add('hidden');
      inviteSuccess.classList.remove('hidden');
    } catch {
      inviteError.textContent = __t('common.networkError');
      inviteError.classList.remove('hidden');
    } finally {
      inviteSubmitBtn.disabled = false;
      inviteSubmitBtn.textContent = __t('users.createInvite');
    }
  });

  document.getElementById('copy-invite-link')!.addEventListener('click', () => {
    navigator.clipboard.writeText(currentInviteLink);
  });

  document.getElementById('done-invite')!.addEventListener('click', () => {
    inviteModal.classList.add('hidden');
    inviteForm.reset();
    loadUsers();
  });
</script>
