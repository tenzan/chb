---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getLocale, t } from '../../i18n';

const locale = getLocale(Astro.cookies.get('lang')?.value);
---

<DashboardLayout title={t(locale, 'nav.enrollments')}>
  <div>
    <div class="flex justify-between items-center mb-4">
      <p id="enrollment-count" class="text-sm text-gray-500">{t(locale, 'common.loading')}</p>
      <button id="enroll-btn" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">
        {t(locale, 'enrollments.enrollStudent')}
      </button>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'enrollments.student')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">{t(locale, 'enrollments.subject')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-[120px]">{t(locale, 'enrollments.started')}</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-[100px]">{t(locale, 'enrollments.status')}</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase w-[120px]">{t(locale, 'common.actions')}</th>
          </tr>
        </thead>
        <tbody id="enrollment-rows" class="divide-y divide-gray-200"></tbody>
      </table>
    </div>
  </div>

  <!-- Enroll Modal -->
  <div id="enroll-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 class="text-lg font-semibold mb-4">{t(locale, 'enrollments.enrollStudent')}</h3>

      <form id="enroll-form" class="space-y-4">
        <div id="enroll-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

        <div>
          <label for="student-select" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'enrollments.student')}</label>
          <select id="student-select" required class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="">{t(locale, 'enrollments.selectStudent')}</option>
          </select>
        </div>

        <div>
          <label for="subject-select" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'enrollments.subject')}</label>
          <select id="subject-select" required class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="">{t(locale, 'enrollments.selectSubject')}</option>
          </select>
        </div>

        <div class="flex gap-2">
          <button type="button" id="cancel-enroll" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
          <button type="submit" id="submit-enroll" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.save')}</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Unenroll Confirmation Modal -->
  <div id="unenroll-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-[100]">
    <div class="bg-white rounded-lg p-6 w-full max-w-sm shadow-xl">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">{t(locale, 'enrollments.unenroll')}</h3>
      <p id="unenroll-message" class="text-sm text-gray-600 mb-4"></p>
      <div id="unenroll-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm mb-4"></div>
      <div class="flex gap-2">
        <button id="cancel-unenroll" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
        <button id="confirm-unenroll" class="flex-1 bg-red-600 text-white py-2 px-4 rounded-md text-sm hover:bg-red-700 disabled:opacity-50">{t(locale, 'enrollments.unenroll')}</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const tbody = document.getElementById('enrollment-rows')!;
  const countEl = document.getElementById('enrollment-count')!;

  const enrollModal = document.getElementById('enroll-modal')!;
  const enrollForm = document.getElementById('enroll-form') as HTMLFormElement;
  const enrollError = document.getElementById('enroll-error')!;
  const submitBtn = document.getElementById('submit-enroll') as HTMLButtonElement;
  const studentSelect = document.getElementById('student-select') as HTMLSelectElement;
  const subjectSelect = document.getElementById('subject-select') as HTMLSelectElement;

  const unenrollModal = document.getElementById('unenroll-modal')!;
  const unenrollMessage = document.getElementById('unenroll-message')!;
  const unenrollError = document.getElementById('unenroll-error')!;
  const confirmUnenrollBtn = document.getElementById('confirm-unenroll') as HTMLButtonElement;

  let enrollments: any[] = [];
  let unenrollingId: string | null = null;

  // escapeHtml: uses DOM textContent/innerHTML to safely escape user-provided strings.
  // This is the same XSS-safe pattern used across all admin pages (subjects.astro, etc.).
  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderEnrollments() {
    const count = enrollments.length;
    countEl.textContent = count === 1
      ? __t('enrollments.enrollmentCountOne', { count: '1' })
      : __t('enrollments.enrollmentCount', { count: String(count) });

    if (enrollments.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-8 text-center text-sm text-gray-500">${escapeHtml(__t('enrollments.noEnrollments'))}</td></tr>`;
      return;
    }

    tbody.innerHTML = enrollments.map(e => {
      const started = new Date(e.started_at).toLocaleDateString();
      const isActive = !e.ended_at;
      const statusBadge = isActive
        ? `<span class="text-green-700 bg-green-50 px-2 py-0.5 rounded-full text-xs font-medium">${escapeHtml(__t('enrollments.active'))}</span>`
        : `<span class="text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full text-xs font-medium">${escapeHtml(__t('enrollments.ended'))}</span>`;
      const actions = isActive
        ? `<button data-unenroll="${e.id}" data-student="${escapeHtml(e.student_name)}" data-subject="${escapeHtml(e.subject_name)}" class="px-3 py-1.5 border border-red-300 text-red-700 bg-red-50 rounded-md text-xs font-medium hover:bg-red-100">${escapeHtml(__t('enrollments.unenroll'))}</button>`
        : '';
      return `<tr class="hover:bg-gray-50">
        <td class="px-4 py-3 text-sm text-gray-900 font-medium">${escapeHtml(e.student_name)}</td>
        <td class="px-4 py-3 text-sm text-gray-500">${escapeHtml(e.subject_name)}</td>
        <td class="px-4 py-3 text-sm text-gray-500">${started}</td>
        <td class="px-4 py-3 text-sm">${statusBadge}</td>
        <td class="px-4 py-3 text-sm text-right">${actions}</td>
      </tr>`;
    }).join('');
  }

  function loadEnrollments() {
    fetch('/api/admin/enrollments', { credentials: 'include' })
      .then(res => res.ok ? res.json() : { data: [] })
      .then(body => {
        enrollments = body.data;
        renderEnrollments();
      });
  }

  function loadDropdowns() {
    return Promise.all([
      fetch('/api/admin/students', { credentials: 'include' }).then(r => r.ok ? r.json() : { data: [] }),
      fetch('/api/admin/subjects', { credentials: 'include' }).then(r => r.ok ? r.json() : { data: [] }),
    ]).then(([studentsBody, subjectsBody]) => {
      studentSelect.innerHTML = `<option value="">${escapeHtml(__t('enrollments.selectStudent'))}</option>` +
        studentsBody.data.map((s: any) => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('');
      subjectSelect.innerHTML = `<option value="">${escapeHtml(__t('enrollments.selectSubject'))}</option>` +
        subjectsBody.data.map((s: any) => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('');
    });
  }

  loadEnrollments();

  // Enroll Student button
  document.getElementById('enroll-btn')!.addEventListener('click', () => {
    enrollError.classList.add('hidden');
    enrollForm.reset();
    loadDropdowns().then(() => {
      enrollModal.classList.remove('hidden');
    });
  });

  // Unenroll - delegation
  tbody.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-unenroll]') as HTMLElement | null;
    if (!btn) return;

    unenrollingId = btn.dataset.unenroll!;
    const studentName = btn.dataset.student || '';
    const subjectName = btn.dataset.subject || '';
    unenrollMessage.textContent = __t('enrollments.confirmUnenroll', { student: studentName, subject: subjectName });
    unenrollError.classList.add('hidden');
    unenrollModal.classList.remove('hidden');
  });

  // Cancel modals
  document.getElementById('cancel-enroll')!.addEventListener('click', () => {
    enrollModal.classList.add('hidden');
    enrollForm.reset();
  });
  document.getElementById('cancel-unenroll')!.addEventListener('click', () => {
    unenrollModal.classList.add('hidden');
    unenrollingId = null;
  });

  // Submit enroll
  enrollForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    enrollError.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = __t('common.saving');

    const student_id = studentSelect.value;
    const subject_id = subjectSelect.value;

    try {
      const res = await fetch('/api/admin/enrollments', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ student_id, subject_id }),
      });

      const body = await res.json();
      if (!res.ok) {
        enrollError.textContent = body.error || __t('enrollments.failedSave');
        enrollError.classList.remove('hidden');
        return;
      }

      enrollModal.classList.add('hidden');
      enrollForm.reset();
      loadEnrollments();
    } catch {
      enrollError.textContent = __t('common.networkError');
      enrollError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = __t('common.save');
    }
  });

  // Confirm unenroll
  confirmUnenrollBtn.addEventListener('click', async () => {
    if (!unenrollingId) return;
    unenrollError.classList.add('hidden');
    confirmUnenrollBtn.disabled = true;
    confirmUnenrollBtn.textContent = __t('common.deleting');

    try {
      const res = await fetch(`/api/admin/enrollments/${unenrollingId}`, {
        method: 'DELETE',
        credentials: 'include',
      });

      if (!res.ok) {
        const body = await res.json();
        unenrollError.textContent = body.error || __t('enrollments.failedUnenroll');
        unenrollError.classList.remove('hidden');
        return;
      }

      unenrollModal.classList.add('hidden');
      unenrollingId = null;
      loadEnrollments();
    } catch {
      unenrollError.textContent = __t('common.networkError');
      unenrollError.classList.remove('hidden');
    } finally {
      confirmUnenrollBtn.disabled = false;
      confirmUnenrollBtn.textContent = __t('enrollments.unenroll');
    }
  });
</script>
