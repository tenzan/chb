---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getLocale, t } from '../../i18n';

const locale = getLocale(Astro.cookies.get('lang')?.value);
---

<DashboardLayout title={t(locale, 'nav.attendance')}>
  <div>
    <!-- Top controls -->
    <div class="flex items-center justify-between mb-4 flex-wrap gap-4">
      <!-- Searchable student combobox -->
      <div class="relative w-72">
        <div class="flex items-center border border-gray-300 rounded-md bg-white">
          <input
            id="student-search"
            type="text"
            autocomplete="off"
            placeholder={t(locale, 'attendance.allStudents')}
            class="flex-1 px-3 py-2 text-sm rounded-md outline-none bg-transparent"
          />
          <button id="clear-student" class="hidden px-2 py-2 text-gray-400 hover:text-gray-600" type="button">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="student-dropdown" class="hidden absolute z-40 mt-1 w-full bg-white border border-gray-200 rounded-md shadow-lg max-h-60 overflow-y-auto">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- Month navigation -->
      <div class="flex items-center gap-2">
        <button id="prev-month" class="p-1.5 rounded-md hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <span id="month-label" class="text-sm font-medium text-gray-900 min-w-[180px] text-center"></span>
        <button id="next-month" class="p-1.5 rounded-md hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <button id="today-btn" class="ml-2 px-3 py-1.5 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
          {t(locale, 'attendance.today')}
        </button>
      </div>
    </div>

    <!-- Legend -->
    <div class="flex items-center gap-4 mb-4 text-xs text-gray-600">
      <div class="flex items-center gap-1.5">
        <span class="text-green-600 text-sm">{"\u25CF"}</span>
        <span>{t(locale, 'attendance.present')}</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-orange-500 text-sm">{"\u25B2"}</span>
        <span>{t(locale, 'attendance.notifiedAbsent')}</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-red-500 text-sm">{"\u2715"}</span>
        <span>{t(locale, 'attendance.absent')}</span>
      </div>
    </div>

    <!-- Calendar container -->
    <div id="calendar-container" class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <!-- Day headers -->
      <div class="grid grid-cols-7 bg-gray-50">
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.0')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.1')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.2')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.3')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.4')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.5')}</div>
        <div class="px-2 py-2 text-xs font-medium text-gray-500 uppercase text-center">{t(locale, 'attendance.dayNamesShort.6')}</div>
      </div>
      <!-- Calendar grid -->
      <div id="calendar-grid" class="grid grid-cols-7"></div>
    </div>
  </div>

  <!-- Attendance recording modal (individual student view) -->
  <div id="attendance-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 id="attendance-modal-title" class="text-lg font-semibold mb-4">{t(locale, 'attendance.recordAttendance')}</h3>
      <div id="attendance-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm mb-4"></div>
      <div id="attendance-subjects" class="space-y-4 max-h-[60vh] overflow-y-auto"></div>
      <div class="flex gap-2 mt-4">
        <button type="button" id="cancel-attendance" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.cancel')}</button>
        <button type="button" id="save-attendance" class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md text-sm hover:bg-blue-700 disabled:opacity-50">{t(locale, 'common.save')}</button>
      </div>
    </div>
  </div>

  <!-- Drill-down modal (aggregate view — click a count) -->
  <div id="drilldown-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 id="drilldown-title" class="text-lg font-semibold mb-4"></h3>
      <div id="drilldown-list" class="max-h-[60vh] overflow-y-auto"></div>
      <div class="flex gap-2 mt-4">
        <button type="button" id="close-drilldown" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-sm hover:bg-gray-50">{t(locale, 'common.close')}</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const studentSearch = document.getElementById('student-search') as HTMLInputElement;
  const studentDropdown = document.getElementById('student-dropdown')!;
  const clearStudentBtn = document.getElementById('clear-student')!;
  const monthLabel = document.getElementById('month-label')!;
  const calendarContainer = document.getElementById('calendar-container')!;
  const calendarGrid = document.getElementById('calendar-grid')!;

  const attendanceModal = document.getElementById('attendance-modal')!;
  const attendanceModalTitle = document.getElementById('attendance-modal-title')!;
  const attendanceError = document.getElementById('attendance-error')!;
  const attendanceSubjects = document.getElementById('attendance-subjects')!;
  const saveBtn = document.getElementById('save-attendance') as HTMLButtonElement;

  const drilldownModal = document.getElementById('drilldown-modal')!;
  const drilldownTitle = document.getElementById('drilldown-title')!;
  const drilldownList = document.getElementById('drilldown-list')!;

  let currentYear = new Date().getFullYear();
  let currentMonth = new Date().getMonth();
  let attendance: any[] = [];
  let enrollments: any[] = [];
  let allStudents: any[] = [];
  let selectedStudentId: string | null = null; // null = "All Students"
  let selectedDate: string | null = null;

  const STATUS_SYMBOLS: Record<string, { symbol: string; colorClass: string; bgClass: string }> = {
    present: { symbol: '\u25CF', colorClass: 'text-green-600', bgClass: 'bg-green-50 hover:bg-green-100 border-green-200' },
    notified_absent: { symbol: '\u25B2', colorClass: 'text-orange-500', bgClass: 'bg-orange-50 hover:bg-orange-100 border-orange-200' },
    absent: { symbol: '\u2715', colorClass: 'text-red-500', bgClass: 'bg-red-50 hover:bg-red-100 border-red-200' },
  };

  const STATUS_LABELS: Record<string, string> = {
    present: 'attendance.present',
    notified_absent: 'attendance.notifiedAbsent',
    absent: 'attendance.absent',
  };

  // All dynamic content inserted via innerHTML is escaped through this function
  // to prevent XSS — the same pattern used across all admin pages in this codebase.
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function pad(n: number): string {
    return n < 10 ? '0' + n : String(n);
  }

  function formatDate(y: number, m: number, d: number): string {
    return `${y}-${pad(m + 1)}-${pad(d)}`;
  }

  function getMonthNames(): string[] {
    let monthNames = __t('attendance.monthNames');
    if (typeof monthNames === 'string') {
      try { monthNames = JSON.parse(monthNames); } catch { monthNames = []; }
    }
    if (!Array.isArray(monthNames)) {
      monthNames = (window as any).__i18n?.attendance?.monthNames || [];
    }
    return monthNames;
  }

  function updateMonthLabel() {
    const names = getMonthNames();
    const name = names[currentMonth] || '';
    monthLabel.textContent = `${name} ${currentYear}`;
  }

  // ── Searchable Combobox ──────────────────────────────

  async function loadStudents() {
    const res = await fetch('/api/admin/students', { credentials: 'include' });
    if (!res.ok) return;
    const body = await res.json();
    allStudents = body.data || [];
  }

  function showDropdown(filter: string) {
    const query = filter.trim().toLowerCase();
    if (!query) {
      studentDropdown.classList.add('hidden');
      return;
    }

    const filtered = allStudents.filter((s: any) => s.name.toLowerCase().includes(query));

    let html = '<div class="py-1">';
    if (filtered.length === 0) {
      html += '<div class="px-3 py-2 text-sm text-gray-400">' + escapeHtml(__t('attendance.noMatchingStudents')) + '</div>';
    } else {
      for (const s of filtered) {
        html += '<div class="student-option px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 text-gray-900" data-id="' + escapeHtml(s.id) + '">'
          + escapeHtml(s.name)
          + '</div>';
      }
    }
    html += '</div>';

    studentDropdown.innerHTML = html;
    studentDropdown.classList.remove('hidden');
  }

  function hideDropdown() {
    setTimeout(() => studentDropdown.classList.add('hidden'), 150);
  }

  function selectStudent(id: string | null, name: string) {
    selectedStudentId = id;
    if (id) {
      studentSearch.value = name;
      clearStudentBtn.classList.remove('hidden');
    } else {
      studentSearch.value = '';
      clearStudentBtn.classList.add('hidden');
    }
    studentDropdown.classList.add('hidden');
    onStudentChange();
  }

  studentSearch.addEventListener('input', () => {
    showDropdown(studentSearch.value);
  });

  studentSearch.addEventListener('blur', hideDropdown);

  studentDropdown.addEventListener('mousedown', (e) => {
    const option = (e.target as HTMLElement).closest('.student-option') as HTMLElement | null;
    if (!option) return;
    e.preventDefault();
    const id = option.dataset.id!;
    const name = option.textContent || '';
    selectStudent(id, name);
  });

  clearStudentBtn.addEventListener('click', () => {
    selectStudent(null, '');
  });

  // ── Data Loading ─────────────────────────────────────

  async function onStudentChange() {
    if (selectedStudentId) {
      await loadEnrollments(selectedStudentId);
    } else {
      enrollments = [];
    }
    await loadAttendance();
    renderCalendar();
  }

  function loadEnrollments(studentId: string) {
    return fetch(`/api/admin/enrollments?student_id=${studentId}`, { credentials: 'include' })
      .then(res => res.ok ? res.json() : { data: [] })
      .then(body => {
        enrollments = (body.data || []).filter((e: any) => !e.ended_at);
      });
  }

  function loadAttendance() {
    const month = `${currentYear}-${pad(currentMonth + 1)}`;
    let url = `/api/admin/attendance?month=${month}`;
    if (selectedStudentId) {
      url += `&student_id=${selectedStudentId}`;
    }
    return fetch(url, { credentials: 'include' })
      .then(res => res.ok ? res.json() : { data: [] })
      .then(body => {
        attendance = body.data || [];
      })
      .catch(() => {
        attendance = [];
      });
  }

  // ── Calendar Rendering ───────────────────────────────

  function renderCalendar() {
    const firstDay = new Date(currentYear, currentMonth, 1);
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

    let startDow = firstDay.getDay() - 1;
    if (startDow < 0) startDow = 6;

    const now = new Date();
    const todayStr = formatDate(now.getFullYear(), now.getMonth(), now.getDate());
    const isAggregateView = !selectedStudentId;

    let html = '';

    for (let i = 0; i < startDow; i++) {
      html += '<div class="min-h-[80px] border-b border-r border-gray-100 bg-gray-50/50"></div>';
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = formatDate(currentYear, currentMonth, d);
      const isToday = dateStr === todayStr;
      const dayRecords = attendance.filter((a: any) => a.date === dateStr);

      let dayNumHtml: string;
      if (isToday) {
        dayNumHtml = '<span class="bg-blue-600 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs font-medium">' + d + '</span>';
      } else {
        dayNumHtml = '<span class="text-xs font-medium text-gray-700">' + d + '</span>';
      }

      let contentHtml = '';
      if (isAggregateView) {
        contentHtml = renderAggregateCell(dateStr, dayRecords);
      } else {
        contentHtml = renderIndividualCell(dayRecords);
      }

      html += '<div data-date="' + dateStr + '" class="min-h-[80px] border-b border-r border-gray-100 p-1.5 cursor-pointer hover:bg-blue-50/50 transition-colors">'
        + '<div class="mb-1">' + dayNumHtml + '</div>'
        + contentHtml
        + '</div>';
    }

    const totalCells = startDow + daysInMonth;
    const remainder = totalCells % 7;
    if (remainder > 0) {
      for (let i = 0; i < 7 - remainder; i++) {
        html += '<div class="min-h-[80px] border-b border-r border-gray-100 bg-gray-50/50"></div>';
      }
    }

    calendarGrid.innerHTML = html;
    updateMonthLabel();
  }

  function renderAggregateCell(dateStr: string, dayRecords: any[]): string {
    if (dayRecords.length === 0) return '';

    const counts: Record<string, number> = { present: 0, notified_absent: 0, absent: 0 };
    for (const rec of dayRecords) {
      if (counts[rec.status] !== undefined) counts[rec.status]++;
    }

    let html = '<div class="space-y-0.5">';
    for (const [status, count] of Object.entries(counts)) {
      if (count === 0) continue;
      const info = STATUS_SYMBOLS[status];
      html += '<button type="button" data-drilldown-date="' + dateStr + '" data-drilldown-status="' + status + '" '
        + 'class="flex items-center gap-1 px-1.5 py-0.5 rounded border text-xs font-medium cursor-pointer transition-colors ' + info.bgClass + '">'
        + '<span class="' + info.colorClass + '">' + info.symbol + '</span>'
        + '<span class="' + info.colorClass + '">' + count + '</span>'
        + '</button>';
    }
    html += '</div>';
    return html;
  }

  function renderIndividualCell(dayRecords: any[]): string {
    if (dayRecords.length === 0) return '';

    let html = '<div class="space-y-0.5">';
    for (const rec of dayRecords) {
      const statusInfo = STATUS_SYMBOLS[rec.status];
      if (!statusInfo) continue;
      const subjectName = rec.subject_name || '';
      const abbr = subjectName.substring(0, 3);
      const statusLabel = __t(STATUS_LABELS[rec.status] || '');
      const title = escapeHtml(subjectName) + ' \u2014 ' + escapeHtml(statusLabel);
      html += '<div class="flex items-center" title="' + title + '">'
        + '<span class="' + statusInfo.colorClass + ' text-xs">' + statusInfo.symbol + '</span>'
        + '<span class="text-[10px] text-gray-400 ml-0.5">' + escapeHtml(abbr) + '</span>'
        + '</div>';
    }
    html += '</div>';
    return html;
  }

  // ── Day Click Handler ────────────────────────────────

  calendarGrid.addEventListener('click', (e) => {
    // Check for drill-down button click (aggregate view)
    const drillBtn = (e.target as HTMLElement).closest('[data-drilldown-date]') as HTMLElement | null;
    if (drillBtn) {
      e.stopPropagation();
      const date = drillBtn.dataset.drilldownDate!;
      const status = drillBtn.dataset.drilldownStatus!;
      openDrilldownModal(date, status);
      return;
    }

    // Regular day cell click
    const cell = (e.target as HTMLElement).closest('[data-date]') as HTMLElement | null;
    if (!cell) return;
    selectedDate = cell.dataset.date!;

    if (selectedStudentId) {
      openAttendanceModal(selectedDate);
    }
    // In aggregate view, clicking the cell (not a count button) does nothing
  });

  // ── Drill-down Modal (Aggregate View) ────���───────────

  function openDrilldownModal(date: string, status: string) {
    const dayRecords = attendance.filter((a: any) => a.date === date && a.status === status);
    const statusLabel = __t(STATUS_LABELS[status] || '');
    const info = STATUS_SYMBOLS[status];

    drilldownTitle.textContent = date + ' \u2014 ' + info.symbol + ' ' + statusLabel;

    if (dayRecords.length === 0) {
      drilldownList.innerHTML = '<p class="text-sm text-gray-400">' + escapeHtml(__t('attendance.noRecords')) + '</p>';
    } else {
      let html = '<table class="w-full"><thead class="bg-gray-50"><tr>'
        + '<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">' + escapeHtml(__t('attendance.student')) + '</th>'
        + '<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">' + escapeHtml(__t('attendance.subject')) + '</th>'
        + '</tr></thead><tbody class="divide-y divide-gray-100">';

      for (const rec of dayRecords) {
        html += '<tr class="hover:bg-gray-50">'
          + '<td class="px-3 py-2 text-sm text-gray-900">' + escapeHtml(rec.student_name || '') + '</td>'
          + '<td class="px-3 py-2 text-sm text-gray-500">' + escapeHtml(rec.subject_name || '') + '</td>'
          + '</tr>';
      }

      html += '</tbody></table>';
      drilldownList.innerHTML = html;
    }

    drilldownModal.classList.remove('hidden');
  }

  document.getElementById('close-drilldown')!.addEventListener('click', () => {
    drilldownModal.classList.add('hidden');
  });

  // ── Attendance Recording Modal (Individual View) ─────

  function openAttendanceModal(date: string) {
    if (enrollments.length === 0) return;

    attendanceModalTitle.textContent = __t('attendance.recordAttendance') + ' \u2014 ' + date;
    attendanceError.classList.add('hidden');

    let html = '';
    for (const enr of enrollments) {
      const subjectName = enr.subject_name || '';
      const existing = attendance.find((a: any) => a.enrollment_id === enr.id && a.date === date);
      const existingStatus = existing ? existing.status : null;
      const existingNote = existing ? (existing.note || '') : '';

      html += '<div data-enrollment-id="' + escapeHtml(enr.id) + '" class="border border-gray-200 rounded-md p-3">'
        + '<div class="text-sm font-medium text-gray-900 mb-2">' + escapeHtml(subjectName) + '</div>'
        + '<div class="flex gap-1 mb-2">'
        + statusButton('present', __t('attendance.present'), existingStatus)
        + statusButton('notified_absent', __t('attendance.notifiedAbsent'), existingStatus)
        + statusButton('absent', __t('attendance.absent'), existingStatus)
        + '</div>'
        + '<input type="text" class="note-input w-full px-2 py-1 text-sm border border-gray-300 rounded-md" placeholder="' + escapeHtml(__t('attendance.noteOptional')) + '" value="' + escapeHtml(existingNote) + '" />'
        + '</div>';
    }

    attendanceSubjects.innerHTML = html;
    attendanceModal.classList.remove('hidden');
  }

  function statusButton(status: string, label: string, activeStatus: string | null): string {
    const isActive = activeStatus === status;
    let classes: string;
    if (isActive) {
      if (status === 'present') classes = 'bg-green-100 border-green-400 text-green-800';
      else if (status === 'notified_absent') classes = 'bg-orange-100 border-orange-400 text-orange-800';
      else classes = 'bg-red-100 border-red-400 text-red-800';
    } else {
      classes = 'border-gray-300 text-gray-600 hover:bg-gray-50';
    }
    return '<button type="button" class="status-btn flex-1 px-2 py-1 text-xs border rounded-md transition-colors ' + classes + '" data-status="' + status + '">' + escapeHtml(label) + '</button>';
  }

  // Status toggle handler
  attendanceSubjects.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.status-btn') as HTMLElement | null;
    if (!btn) return;
    const row = btn.closest('[data-enrollment-id]') as HTMLElement;
    if (!row) return;

    const status = btn.dataset.status!;

    row.querySelectorAll('.status-btn').forEach(b => {
      b.className = 'status-btn flex-1 px-2 py-1 text-xs border rounded-md transition-colors border-gray-300 text-gray-600 hover:bg-gray-50';
    });

    let activeClasses: string;
    if (status === 'present') activeClasses = 'bg-green-100 border-green-400 text-green-800';
    else if (status === 'notified_absent') activeClasses = 'bg-orange-100 border-orange-400 text-orange-800';
    else activeClasses = 'bg-red-100 border-red-400 text-red-800';

    btn.className = 'status-btn flex-1 px-2 py-1 text-xs border rounded-md transition-colors ' + activeClasses;
  });

  document.getElementById('cancel-attendance')!.addEventListener('click', () => {
    attendanceModal.classList.add('hidden');
  });

  // Save handler
  saveBtn.addEventListener('click', async () => {
    attendanceError.classList.add('hidden');
    saveBtn.disabled = true;
    saveBtn.textContent = __t('common.saving');

    try {
      const rows = attendanceSubjects.querySelectorAll('[data-enrollment-id]');
      for (const row of rows) {
        const enrollmentId = (row as HTMLElement).dataset.enrollmentId;
        const activeBtn = row.querySelector('.status-btn.bg-green-100, .status-btn.bg-orange-100, .status-btn.bg-red-100') as HTMLElement | null;
        if (!activeBtn) continue;

        const status = activeBtn.dataset.status;
        const noteInput = row.querySelector('.note-input') as HTMLInputElement;
        const note = noteInput ? noteInput.value.trim() : '';

        const res = await fetch('/api/admin/attendance', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            enrollment_id: enrollmentId,
            date: selectedDate,
            status,
            note: note || undefined,
          }),
        });

        if (!res.ok) {
          const body = await res.json();
          attendanceError.textContent = body.error || __t('attendance.failedSave');
          attendanceError.classList.remove('hidden');
          return;
        }
      }

      attendanceModal.classList.add('hidden');
      await loadAttendance();
      renderCalendar();
    } catch {
      attendanceError.textContent = __t('common.networkError');
      attendanceError.classList.remove('hidden');
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = __t('common.save');
    }
  });

  // ── Month Navigation ────────────────────────────��────

  document.getElementById('prev-month')!.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    loadAndRender();
  });

  document.getElementById('next-month')!.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    loadAndRender();
  });

  document.getElementById('today-btn')!.addEventListener('click', () => {
    const now = new Date();
    currentYear = now.getFullYear();
    currentMonth = now.getMonth();
    loadAndRender();
  });

  function loadAndRender() {
    loadAttendance().then(() => renderCalendar());
  }

  // ── Init ─────────────────────────────────────────────

  async function init() {
    await loadStudents();
    await loadAttendance();
    renderCalendar();
  }

  init();
</script>
