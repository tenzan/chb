---
import PublicLayout from "../layouts/PublicLayout.astro";

const token = Astro.url.searchParams.get("token") || "";

if (!token) {
  return Astro.redirect("/login");
}
---

<PublicLayout title="Reset Password">
  <div id="loading" class="text-center text-gray-500 py-8">Validating link...</div>

  <div id="invalid" class="hidden text-center py-8">
    <p class="text-red-600 mb-4">This reset link is invalid, expired, or has already been used.</p>
    <a href="/login" class="text-blue-600 hover:underline">Go to login</a>
  </div>

  <form id="reset-form" class="hidden space-y-4">
    <h1 class="text-2xl font-bold text-gray-900 text-center mb-2">
      Reset Password
    </h1>
    <p id="user-info" class="text-sm text-gray-500 text-center mb-4"></p>

    <div id="error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-md text-sm"></div>

    <div>
      <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
        New Password
      </label>
      <input
        id="password"
        type="password"
        required
        minlength="6"
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <div>
      <label for="confirm-password" class="block text-sm font-medium text-gray-700 mb-1">
        Confirm Password
      </label>
      <input
        id="confirm-password"
        type="password"
        required
        minlength="6"
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 disabled:opacity-50"
    >
      Reset Password
    </button>
  </form>

  <div id="success" class="hidden text-center py-8">
    <p class="text-green-600 mb-4">Your password has been reset successfully.</p>
    <a href="/login" class="text-blue-600 hover:underline">Go to login</a>
  </div>
</PublicLayout>

<script define:vars={{ token }}>
  const loadingEl = document.getElementById('loading');
  const invalidEl = document.getElementById('invalid');
  const form = document.getElementById('reset-form');
  const errorEl = document.getElementById('error');
  const successEl = document.getElementById('success');
  const userInfo = document.getElementById('user-info');
  const submitBtn = form.querySelector('button[type="submit"]');

  // Validate token on load
  fetch(`/api/auth/reset-password?token=${encodeURIComponent(token)}`, {
    credentials: 'include',
  })
    .then(res => res.json().then(body => ({ ok: res.ok, body })))
    .then(({ ok, body }) => {
      loadingEl.classList.add('hidden');
      if (!ok) {
        invalidEl.classList.remove('hidden');
        return;
      }
      userInfo.textContent = `Resetting password for ${body.data.name || body.data.email}`;
      form.classList.remove('hidden');
    })
    .catch(() => {
      loadingEl.classList.add('hidden');
      invalidEl.classList.remove('hidden');
    });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm-password').value;

    if (password !== confirmPassword) {
      errorEl.textContent = 'Passwords do not match';
      errorEl.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Resetting...';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });

      const body = await res.json();

      if (!res.ok) {
        errorEl.textContent = body.error || 'Failed to reset password';
        errorEl.classList.remove('hidden');
        return;
      }

      form.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch {
      errorEl.textContent = 'Network error';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Reset Password';
    }
  });
</script>
