---
import { getLocale, t, getAllTranslations } from '../i18n';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocale(Astro.cookies.get('lang')?.value);
const translations = JSON.stringify(getAllTranslations(locale));

const navItems = [
  { href: "/admin", label: t(locale, "nav.dashboard") },
  { href: "/admin/users", label: t(locale, "nav.users") },
  { href: "/admin/subjects", label: t(locale, "nav.subjects") },
  { href: "/admin/enrollments", label: t(locale, "nav.enrollments") },
  { href: "/admin/attendance", label: t(locale, "nav.attendance") },
  { href: "/admin/deployments", label: t(locale, "nav.deployments") },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script define:vars={{ translations }}>
      const __i18n = JSON.parse(translations);
      window.__i18n = __i18n;
      window.__t = function(key, params) {
        let value = __i18n;
        const parts = key.split('.');
        for (const part of parts) {
          value = value?.[part];
        }
        if (typeof value !== 'string') return key;
        if (params) {
          return value.replace(/\{(\w+)\}/g, (_, k) => params[k] ?? `{${k}}`);
        }
        return value;
      };
    </script>
  </head>
  <body class="min-h-screen bg-gray-50">
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-64 min-h-screen bg-white border-r border-gray-200 p-4">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-gray-900">{t(locale, "nav.admin")}</h1>
          <p id="user-name" class="text-sm text-gray-500 mt-1"></p>
        </div>

        <nav class="space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium ${
                currentPath === item.href || (item.href !== "/admin" && currentPath.startsWith(item.href))
                  ? "bg-blue-50 text-blue-700"
                  : "text-gray-700 hover:bg-gray-50"
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="mt-8 pt-4 border-t border-gray-200">
          <button
            type="button"
            id="logout-btn"
            class="w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md"
          >
            {t(locale, "nav.logout")}
          </button>
        </div>

        <p class="mt-4 px-3 text-[10px] text-gray-300 group/sha flex items-center gap-1">
          <span>{__COMMIT_SHA__}</span>
          <button id="copy-sha-btn" class="opacity-0 group-hover/sha:opacity-100 transition-opacity text-gray-300 hover:text-gray-500" title="Copy SHA">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke-width="2"/></svg>
          </button>
        </p>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col">
        <!-- Top bar -->
        <header class="flex items-center justify-between px-8 py-4 border-b border-gray-200 bg-white">
          <h2 class="text-2xl font-bold text-gray-900">{title}</h2>
          <!-- Language Switcher -->
          <div class="flex items-center gap-1">
            <button
              data-lang="en"
              class={`px-2.5 py-1 text-xs rounded-md font-medium transition-colors ${locale === 'en' ? 'bg-blue-600 text-white' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-100'}`}
            >
              EN
            </button>
            <button
              data-lang="ru"
              class={`px-2.5 py-1 text-xs rounded-md font-medium transition-colors ${locale === 'ru' ? 'bg-blue-600 text-white' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-100'}`}
            >
              RU
            </button>
          </div>
        </header>

        <main class="flex-1 p-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      // Language switcher
      document.querySelectorAll('[data-lang]').forEach(btn => {
        btn.addEventListener('click', () => {
          const lang = (btn as HTMLElement).dataset.lang!;
          document.cookie = `lang=${lang};path=/;max-age=${365 * 24 * 60 * 60};SameSite=Lax`;
          window.location.reload();
        });
      });

      // Auth check + populate user name
      fetch("/api/auth/me", { credentials: "include" })
        .then((res) => {
          if (!res.ok) throw new Error("Not authenticated");
          return res.json();
        })
        .then((body) => {
          const el = document.getElementById("user-name");
          if (el) el.textContent = body.data.name;
        })
        .catch(() => {
          window.location.href = "/login";
        });

      // Copy SHA
      const copyBtn = document.getElementById("copy-sha-btn");
      if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(__COMMIT_SHA_FULL__);
          const svg = copyBtn.querySelector("svg")!;
          const original = svg.outerHTML;
          svg.outerHTML = '<svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          setTimeout(() => {
            const tick = copyBtn.querySelector("svg");
            if (tick) tick.outerHTML = original;
          }, 1500);
        });
      }

      // Logout
      const btn = document.getElementById("logout-btn");
      if (btn) {
        btn.addEventListener("click", async () => {
          await fetch("/api/auth/logout", {
            method: "POST",
            credentials: "include",
          });
          window.location.href = "/login";
        });
      }
    </script>
  </body>
</html>
