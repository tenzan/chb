---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/admin", label: "Dashboard" },
  { href: "/admin/users", label: "Users" },
  { href: "/admin/subjects", label: "Subjects" },
  { href: "/admin/deployments", label: "Deployments" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-64 min-h-screen bg-white border-r border-gray-200 p-4">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-gray-900">Admin</h1>
          <p id="user-name" class="text-sm text-gray-500 mt-1"></p>
        </div>

        <nav class="space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium ${
                currentPath === item.href || (item.href !== "/admin" && currentPath.startsWith(item.href))
                  ? "bg-blue-50 text-blue-700"
                  : "text-gray-700 hover:bg-gray-50"
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="mt-8 pt-4 border-t border-gray-200">
          <button
            type="button"
            id="logout-btn"
            class="w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md"
          >
            Logout
          </button>
        </div>

        <p class="mt-4 px-3 text-[10px] text-gray-300 group/sha flex items-center gap-1">
          <span>{__COMMIT_SHA__}</span>
          <button id="copy-sha-btn" class="opacity-0 group-hover/sha:opacity-100 transition-opacity text-gray-300 hover:text-gray-500" title="Copy SHA">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke-width="2"/></svg>
          </button>
        </p>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{title}</h2>
        <slot />
      </main>
    </div>

    <script>
      // Auth check + populate user name
      fetch("/api/auth/me", { credentials: "include" })
        .then((res) => {
          if (!res.ok) throw new Error("Not authenticated");
          return res.json();
        })
        .then((body) => {
          const el = document.getElementById("user-name");
          if (el) el.textContent = body.data.name;
        })
        .catch(() => {
          window.location.href = "/login";
        });

      // Copy SHA
      const copyBtn = document.getElementById("copy-sha-btn");
      if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(__COMMIT_SHA_FULL__);
          const svg = copyBtn.querySelector("svg")!;
          const original = svg.outerHTML;
          svg.outerHTML = '<svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          setTimeout(() => {
            const tick = copyBtn.querySelector("svg");
            if (tick) tick.outerHTML = original;
          }, 1500);
        });
      }

      // Logout
      const btn = document.getElementById("logout-btn");
      if (btn) {
        btn.addEventListener("click", async () => {
          await fetch("/api/auth/logout", {
            method: "POST",
            credentials: "include",
          });
          window.location.href = "/login";
        });
      }
    </script>
  </body>
</html>
