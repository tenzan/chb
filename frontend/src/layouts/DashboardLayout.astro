---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const runtime = Astro.locals.runtime;
const apiUrl = runtime?.env?.PUBLIC_API_URL || import.meta.env.PUBLIC_API_URL || "http://localhost:8787";

const navItems = [
  { href: "/admin", label: "Dashboard" },
  { href: "/admin/users", label: "Users" },
  { href: "/admin/parents", label: "Parents" },
  { href: "/admin/students", label: "Students" },
  { href: "/admin/deployments", label: "Deployments" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <script define:vars={{ apiUrl }}>window.__API_URL__ = apiUrl;</script>
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-64 min-h-screen bg-white border-r border-gray-200 p-4">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-gray-900">Admin</h1>
          <p id="user-name" class="text-sm text-gray-500 mt-1"></p>
        </div>

        <nav class="space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium ${
                currentPath === item.href || (item.href !== "/admin" && currentPath.startsWith(item.href))
                  ? "bg-blue-50 text-blue-700"
                  : "text-gray-700 hover:bg-gray-50"
              }`}
            >
              {item.label}
              {item.href === "/admin/deployments" && (
                <span id="deploy-indicator" class="hidden w-2.5 h-2.5 rounded-full animate-pulse"></span>
              )}
            </a>
          ))}
        </nav>

        <div class="mt-8 pt-4 border-t border-gray-200">
          <button
            type="button"
            id="logout-btn"
            class="w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md"
          >
            Logout
          </button>
        </div>

        <p class="mt-4 px-3 text-[10px] text-gray-300">{__COMMIT_SHA__}</p>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{title}</h2>
        <slot />
      </main>
    </div>

    <script>
      // Auth check + populate user name
      const url = window.__API_URL__ || "http://localhost:8787";
      fetch(`${url}/api/auth/me`, { credentials: "include" })
        .then((res) => {
          if (!res.ok) throw new Error("Not authenticated");
          return res.json();
        })
        .then((body) => {
          const el = document.getElementById("user-name");
          if (el) el.textContent = body.data.name;
        })
        .catch(() => {
          window.location.href = "/login";
        });

      // Deploy status indicator
      const indicator = document.getElementById("deploy-indicator");
      if (indicator) {
        let deployPoll: ReturnType<typeof setInterval> | null = null;
        async function checkDeploys() {
          try {
            const r = await fetch("/api/admin/deployments?limit=5");
            const d = await r.json();
            if (d.error) return;
            const isActive = (run: any) => run && (run.status === "in_progress" || run.status === "queued" || run.status === "waiting");
            const stagingActive = d.stagingRuns?.some(isActive);
            const prodActive = d.productionRuns?.some(isActive);
            const canPromote = d.latestStaging?.conclusion === "success"
              && (!d.latestProduction?.conclusion || d.latestStaging.head_sha_full !== d.latestProduction.head_sha_full);
            if (prodActive) {
              indicator.className = "w-2.5 h-2.5 rounded-full animate-pulse bg-orange-500";
            } else if (stagingActive) {
              indicator.className = "w-2.5 h-2.5 rounded-full animate-pulse bg-blue-500";
            } else if (canPromote) {
              indicator.className = "w-2.5 h-2.5 rounded-full bg-yellow-400";
            } else {
              indicator.className = "hidden w-2.5 h-2.5 rounded-full";
              if (deployPoll) { clearInterval(deployPoll); deployPoll = null; }
            }
          } catch {}
        }
        checkDeploys();
        deployPoll = setInterval(checkDeploys, 10000);
        (window as any).__checkDeploys = checkDeploys;
      }

      // Logout
      const btn = document.getElementById("logout-btn");
      if (btn) {
        btn.addEventListener("click", async () => {
          await fetch(`${url}/api/auth/logout`, {
            method: "POST",
            credentials: "include",
          });
          window.location.href = "/login";
        });
      }
    </script>
  </body>
</html>
