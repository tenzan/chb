---
interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;
const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:8787";

const navItems = [
  { href: "/admin", label: "Dashboard" },
  { href: "/admin/users", label: "Users" },
  { href: "/admin/parents", label: "Parents" },
  { href: "/admin/students", label: "Students" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Learning Center</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <script define:vars={{ apiUrl }}>window.__API_URL__ = apiUrl;</script>
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-64 min-h-screen bg-white border-r border-gray-200 p-4">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-gray-900">Learning Center</h1>
          {user && (
            <p class="text-sm text-gray-500 mt-1">{user.name}</p>
          )}
        </div>

        <nav class="space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`block px-3 py-2 rounded-md text-sm font-medium ${
                currentPath === item.href || (item.href !== "/admin" && currentPath.startsWith(item.href))
                  ? "bg-blue-50 text-blue-700"
                  : "text-gray-700 hover:bg-gray-50"
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="mt-8 pt-4 border-t border-gray-200">
          <form method="POST" action="/api/auth/logout" id="logout-form">
            <button
              type="button"
              id="logout-btn"
              class="w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md"
            >
              Logout
            </button>
          </form>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{title}</h2>
        <slot />
      </main>
    </div>

    <script>
      const btn = document.getElementById("logout-btn");
      if (btn) {
        btn.addEventListener("click", async () => {
          const url = window.__API_URL__ || "http://localhost:8787";
          await fetch(`${url}/api/auth/logout`, {
            method: "POST",
            credentials: "include",
          });
          window.location.href = "/login";
        });
      }
    </script>
  </body>
</html>
